# Copy to .env and fill in. .env is gitignored — keep it that way.
# The web app deliberately reads NO environment variables; these are worker-side only.

# Tavily — external verification of claims about entities ALREADY INDEXED on the public web
# (market comparables, prior funding rounds). Not used for receipt fetches: our fixture pages
# are hours old and a search index has never crawled them. Receipts use a direct httpx GET.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM — structured-output extraction and claim typing only.
# The model never emits a score and never writes prose; scoring is closed-form numpy so that
# leave-one-out attribution stays exact.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# USPTO Open Data Portal — the flagship sourcing channel (self-filed trademarks).
# Optional: registration needs identity verification that can take hours, so the daily bulk XML
# committed as a dated fixture is the primary path, not the fallback.
# USPTO_API_KEY=

# Supabase — NOT required to run anything. The local SQLite ledger at db/counterproof.db is the
# store. These exist only if we later push the schema up for the on-camera "append-only ledger"
# view. The frontend never talks to a database.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
