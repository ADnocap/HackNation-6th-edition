# Normalize line endings: LF in the repo, native in the working tree.
# Keeps diffs clean across Windows / macOS / Linux teammates.
* text=auto eol=lf

# Binary assets — never touch these.
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.db    binary
*.sqlite binary
*.sqlite3 binary

# Generated — collapse in diffs and mark as not-authored for language stats.
web/package-lock.json linguist-generated=true -diff
uv.lock               linguist-generated=true -diff
